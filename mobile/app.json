{
  "expo": {
    "name": "Albert",
    "slug": "albert",
    "scheme": "albert",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.albert.app"
    },
    "android": {
      "package": "com.albert.app"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    }
  }
}
